  "theme": "base",
  "themeVariables": {
    "fontSize": "20px",
    "fontFamily": "Arial, sans-serif",
    "primaryColor": "#dbeafe",
    "primaryTextColor": "#1e3a5f",
    "primaryBorderColor": "#3b82f6",
    "lineColor": "#475569",
